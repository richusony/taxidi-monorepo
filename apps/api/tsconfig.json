{
  "extends": "@taxidi/tsconfig/base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@lib/*": ["./src/lib/*"],
      "@utils/*": ["./src/utils/*"],
      "@v1/*": ["./src/v1/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}

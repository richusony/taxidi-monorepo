generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
}

model Users {
  id        String  @id @default(uuid())
  firstname String
  lastname  String?
  email     String  @unique
  googleId  String?
  phone     String? @unique
  password  String?

  roles UserRole[]

  company       RentalCompany?
  vehicles      Vehicles[]
  refresh_token RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@map("users")
}

model Role {
  id   String @id @default(uuid())
  name RoleName @unique

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id   String @id @default(uuid())
  name String @unique

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId String
  roleId String

  user Users @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@index([roleId])

  @@map("user_roles")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@index([permissionId])

@@map("role_permissions")
}

model RentalCompany {
  id                  String  @id @default(uuid())
  company_name        String
  owner_id            String  @unique
  owner               Users   @relation(fields: [owner_id], references: [id])
  company_location_id String?  @unique
  company_location    Address? @relation(fields: [company_location_id], references: [id])
  is_blocked          Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("rental_company")
}

model Vehicles {
  id String @id @default(uuid())

  brand String
  model String

  kilometers_driven Int
  vehicle_age       Int
  mileage           Float

  owner_id String
  owner    Users  @relation(fields: [owner_id], references: [id])

  is_blocked Boolean @default(false)

  price_per_hour_subunits Int
  price_per_week_subunits Int

  pickup_location_id String
  pickup_location    Address @relation(fields: [pickup_location_id], references: [id])

  current_status VehicleStatus @default(AVAILABLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([owner_id, pickup_location_id])
  @@map("vehicles")
}

model Address {
  id               String     @id @default(uuid())
  address_line_one String
  address_line_two String?
  address_tag      AddressTag @default(COMPANY)
  latitude         Float?
  longitude        Float?

  company RentalCompany?

  vehicles   Vehicles[]


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("address")
}

model RefreshToken {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  userId     String
  user       Users    @relation(fields: [userId], references: [id])
  expiresAt  DateTime
  createdAt DateTime @default(now())
  revoked    Boolean  @default(false)

  @@index([tokenHash])
  @@map("refresh_token")
}

// enums

enum RoleName {
  CUSTOMER
  PARTNER
  ADMIN
}

enum VehicleStatus {
  AVAILABLE
  BOOKED
  MAINTENANCE
}

enum AddressTag {
  HOME
  COMPANY
}
